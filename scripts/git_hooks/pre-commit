#!/usr/bin/env bash
set -euo pipefail

# Build pattern strings indirectly to avoid self-matching (§11.4.75)
M1="MUT""ATED"
M2="// alwa""ys pass"
M3="# MUT""ATION"

MUTATION_PATTERNS=(
  "$M1"
  "$M2"
  "$M3"
)

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
  exit 0
fi

violations=0

while IFS= read -r file; do
  [ -f "$file" ] || continue
  for pattern in "${MUTATION_PATTERNS[@]}"; do
    if grep -n "$pattern" "$file" >/dev/null 2>&1; then
      echo "CONSTITUTION-§11.4.75: mutation marker '$pattern' found in $file"
      grep -n "$pattern" "$file"
      violations=$((violations + 1))
    fi
  done
done <<< "$STAGED"

if [ "$violations" -gt 0 ]; then
  echo "CONSTITUTION-§11.4.75: commit blocked — $violations mutation marker(s) detected."
  echo "Use 'git commit --no-verify' only with a Bypass-rationale footer."
  exit 1
fi

exit 0
