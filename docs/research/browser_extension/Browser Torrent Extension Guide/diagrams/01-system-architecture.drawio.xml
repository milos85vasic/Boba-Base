        </mxCell>

        <mxCell id="flow2-label" value="&lt;b&gt;Batch Processing Flow — Tab Groups:&lt;/b&gt;\n① User opens context menu on Tab Group → ② Background SW queries chrome.tabGroups → ③ chrome.tabs.query for each group\n④ Content Script injected per tab → ⑤ All torrents collected → ⑥ Batch API call to Boba Service → ⑦ All torrents added to qBitTorrent" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#555555;fontFamily=system-ui;whiteSpace=wrap;" parent="legend" vertex="1">
